[gd_scene load_steps=2 format=3 uid="uid://cdnslfev1lkmg"]

[sub_resource type="GDScript" id="GDScript_fftxt"]
script/source = "class_name CollectableComponent
extends Area2D

@export var collectable_name: String




func _on_body_entered(body: Node2D) -> void:
	if body is Player:
		print(\"Collected:\", collectable_name)
		get_parent().queue_free()
"

[node name="CollectableComponent" type="Area2D"]
collision_layer = 32
collision_mask = 2
script = SubResource("GDScript_fftxt")

[connection signal="area_entered" from="." to="." method="_on_area_entered"]
